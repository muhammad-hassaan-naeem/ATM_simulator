# Copy this file to .env and fill in your values
# The app reads DB_BACKEND to decide which database to use.
# Set DB_BACKEND=sqlite  (default, no extra setup needed)
# Set DB_BACKEND=mysql   (requires a running MySQL server)

DB_BACKEND=sqlite

# --- SQLite (default) ---
# Path to the SQLite database file (relative to project root)
SQLITE_PATH=atm.db

# --- MySQL (only needed if DB_BACKEND=mysql) ---
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=atm
